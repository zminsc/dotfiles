# ~/.config/tofi/config

# Font
font = NotoSansM Nerd Font Mono

# Window appearance
width = 600
height = 250
border-width = 1
border-color = #7aa2f7
background-color = #1a1b26
outline-width = 0

# Input field
prompt-text = " > "
prompt-padding = 5
prompt-color = #7aa2f7
prompt-background = #00000000
prompt-background-padding = 0
prompt-background-corner-radius = 0

# Text styling
font-size = 10
text-color = #c0caf5
default-result-color = #c0caf5
placeholder-color = #545c7e

# Selection styling
selection-color = #c0caf5
selection-background = #283457
selection-background-padding = 5
selection-background-corner-radius = 2
selection-match-color = #73daca
selection-background-padding = 5

# Results area
result-spacing = 9
num-results = 7
padding-top = 10
padding-bottom = 10
padding-left = 10
padding-right = 10

# Matching
matching-algorithm = fuzzy
drun-launch = true

# Positioning
anchor = top
margin-top = 40%
margin-bottom = 0
margin-left = 0
margin-right = 0
